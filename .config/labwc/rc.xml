<labwc_config>

<core>
	<decoration>server</decoration>
</core>

<keyboard>

	<layoutScope>global</layoutScope>

	<repeatRate>50</repeatRate>
	<repeatDelay>250</repeatDelay>

	<keybind key="W-S-Return">
		<action name="Execute" command="alacritty" />
	</keybind>

	<keybind key="W-S-c">
		<action name="Close"/>
	</keybind>

	<keybind key="W-p">
		<action name="Execute" command="mew-run -i" />
	</keybind>

	<keybind key="W-S-q">
		<action name="Execute" command="labwc --exit" />
	</keybind>

	<keybind key="W-j">
		<action name="NextWindowImmediate" />
	</keybind>

	<keybind key="W-k">
		<action name="PreviousWindowImmediate" />
	</keybind>

	<keybind key="W-m">
		<action name="ToggleMaximize" />
	</keybind>

	<keybind key="W-Left">
		<action name="SnapToEdge" direction="left" combine="yes" />
	</keybind>

	<keybind key="W-Right">
		<action name="SnapToEdge" direction="right" combine="yes" />
	</keybind>

	<keybind key="W-Up">
		<action name="SnapToEdge" direction="up" combine="yes" />
	</keybind>

	<keybind key="W-Down">
		<action name="SnapToEdge" direction="down" combine="yes" />
	</keybind>

	<keybind key="W-1">
		<action name="GoToDesktop" to="1" />
	</keybind>

	<keybind key="W-2">
		<action name="GoToDesktop" to="2" />
	</keybind>

	<keybind key="W-3">
		<action name="GoToDesktop" to="3" />
	</keybind>

	<keybind key="W-4">
		<action name="GoToDesktop" to="4" />
	</keybind>

	<keybind key="W-5">
		<action name="GoToDesktop" to="5" />
	</keybind>

	<keybind key="W-6">
		<action name="GoToDesktop" to="6" />
	</keybind>

	<keybind key="W-7">
		<action name="GoToDesktop" to="7" />
	</keybind>

	<keybind key="W-8">
		<action name="GoToDesktop" to="8" />
	</keybind>

	<keybind key="W-9">
		<action name="GoToDesktop" to="9" />
	</keybind>

	<keybind key="W-0">
		<action name="GoToDesktop" to="10" />
	</keybind>

	<keybind key="W-S-1">
		<action name="SendToDesktop" to="1"  follow="no" />
	</keybind>

	<keybind key="W-S-2">
		<action name="SendToDesktop" to="2" follow="no" />
	</keybind>

	<keybind key="W-S-3">
		<action name="SendToDesktop" to="3" follow="no" />
	</keybind>

	<keybind key="W-S-4">
		<action name="SendToDesktop" to="4" follow="no" />
	</keybind>

	<keybind key="W-S-5">
		<action name="SendToDesktop" to="5" follow="no" />
	</keybind>

	<keybind key="W-S-6">
		<action name="SendToDesktop" to="6" follow="no" />
	</keybind>

	<keybind key="W-S-7">
		<action name="SendToDesktop" to="7" follow="no" />
	</keybind>

	<keybind key="W-S-8">
		<action name="SendToDesktop" to="8" follow="no" />
	</keybind>

	<keybind key="W-S-9">
		<action name="SendToDesktop" to="9" follow="no" />
	</keybind>

	<keybind key="W-S-0">
		<action name="SendToDesktop" to="10" follow="no" />
	</keybind>

	 <keybind key="W-b">
		<action name="ToggleDecorations" />
	</keybind>

	<!-- My custom binds-->

	<keybind key="W-S-b">
		<action name="Execute" command="firefox" />
	</keybind>

	<keybind key="W-e">
		<action name="Execute" command="alacritty -e lf" />
	</keybind>

	<keybind key="W-S-m">
		<action name="Execute" command="alacritty -e ncmpcpp" />
	</keybind>

	<keybind key="W-n">
		<action name="Execute" command="alacritty -e newsboat" />
	</keybind>

	<keybind key="W-S-t">
		<action name="Execute" command="alacritty -e htop" />
	</keybind>

	<keybind key="W-u">
		<action name="Execute" command="alacritty -e pulsemixer" />
	</keybind>

	<keybind key="W-y">
		<action name="Execute" command="alacritty -e ~/.local/bin/yt-launcher.sh" />
	</keybind>
	
	<keybind key="W-S-y">
		<action name="Execute" command="alacritty -e ~/.local/bin/yt-downloader.sh" />
	</keybind>

	<keybind key="W-A-m">
		<action name="Execute" command="alacritty -e ~/.local/bin/music-downloader.sh" />
	</keybind>

	<keybind key="XF86AudioRaiseVolume">
		<action name="Execute" command="bash ~/.local/bin/volume.sh up" />
	</keybind>

	<keybind key="XF86AudioLowerVolume">
		<action name="Execute" command="bash ~/.local/bin/volume.sh down" />
	</keybind>

	<keybind key="XF86AudioMute">
		<action name="Execute" command="bash ~/.local/bin/volume.sh mute" />
	</keybind>

	<keybind key="W-w">
		<action name="Execute" command="bash ~/.local/bin/volume.sh up" />
	</keybind>

	<keybind key="W-s">
		<action name="Execute" command="bash ~/.local/bin/volume.sh down" />
	</keybind>

	<keybind key="W-S-s">
		<action name="Execute" command="bash ~/.local/bin/volume.sh mute" />
	</keybind>

	<keybind key="W-z">
		<action name="Execute" command="bash ~/.local/bin/screenshot.sh select" />
	</keybind>

	<keybind key="W-S-z">
		<action name="Execute" command="bash ~/.local/bin/screenshot.sh focused" />
	</keybind>

	<keybind key="W-S-z">
		<action name="Execute" command="bash ~/.local/bin/screenshot-wl.sh focused" />
	</keybind>

	<keybind key="W-S-z">
		<action name="Execute" command="bash ~/.local/bin/screenshot-wl.sh focused" />
	</keybind>

	<keybind key="W-bracketright">
		<action name="Execute" command="playerctl next" />
	</keybind>

	<keybind key="W-bracketleft">
		<action name="Execute" command="playerctl previous" />
	</keybind>

	<keybind key="W-backslash">
		<action name="Execute" command="playerctl play-pause" />
	</keybind>

	<keybind key="W-v">
		<action name="Execute" command="~/.local/bin/clipboard.sh" />
	</keybind>

	<keybind key="W-S-v">
		<action name="Execute" command="cliphist wipe" />
	</keybind>

</keyboard>

<focus>
	<followMouse>yes</followMouse>
</focus>

    <desktops>
      <popupTime>1500</popupTime>
      <initial>1</initial>
      <names>
        <name>1</name>
        <name>2</name>
        <name>3</name>
        <name>4</name>
        <name>5</name>
        <name>6</name>
        <name>7</name>
        <name>8</name>
        <name>9</name>
        <name>10</name>
      </names>
    </desktops>

<windowRules>
	<windowRule identifier="*">
		<action name="SetDecorations" decorations="border" />
		<action name="AutoPlace" policy="center" />
	</windowRule>
</windowRules>

  <libinput>
    <device category="default">
      <pointerSpeed>0.3</pointerSpeed>
      <accelProfile>flat</accelProfile>
      <tap>yes</tap>
      <scrollFactor>1.0</scrollFactor>
    </device>
  </libinput>

</labwc_config>
