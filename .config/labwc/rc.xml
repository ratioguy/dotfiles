<labwc_config>

<keyboard>
    <repeatRate>50</repeatRate>
    <repeatDelay>250</repeatDelay>

    <default />
    <!-- Use a different terminal emulator -->
    <keybind key="W-S-Return">
      <action name="Execute" command="foot" />
    </keybind>

    <keybind key="W-S-c">
      <action name="close" />
    </keybind>

    <keybind key="W-P">
      <action name="Execute" command="mew-run" />
    </keybind>

    <keybind key="W-b">
      <action name="ToggleDecorations" />
    </keybind> 

    <!--
	    Unbind default bindings
    -->
    <keybind key="W-Return">
     <action name="None" />
    </keybind>

    <keybind key="W-F4">
      <action name="None" />
    </keybind>

    <keybind key="A-F4">
      <action name="None" />
    </keybind>
</keyboard>

  <windowRules>
    <windowRule identifier="*">
      <action name="SetDecorations" decorations="border" />
    </windowRule>
  </windowRules>

</labwc_config>
