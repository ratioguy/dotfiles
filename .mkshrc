# PS1 style
PS1="[\$USER@$(hostname) \$PWD]$ "

# Set history file/settings
HISTFILE=~/.cache/mksh_history
HISTSIZE=10000
SAVEHIST=10000

# Source aliases from aliasrc file
source ~/.config/aliasrc

# Bind ctrl + L to clear screen
bind ^L=clear-screen

# Make lf change directory on exit
lf () {
    cd "$(command lf -print-last-dir "$@")"
}

# Set shell enviornment Varibles
export FZF_DEFAULT_COMMAND="fdfind . ~ --hidden"
export EDITOR="vi"
export PATH=~/.local/bin:$PATH
